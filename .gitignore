# ===========================================
# LibreChoice .gitignore
# Django (backend) + Vite/React (frontend)
# ===========================================

# ---------- Python / Django ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---------- Django específico ----------
# NO subir la base de datos SQLite a git (se regenera con el CSV + import_courses)
db.sqlite3
db.sqlite3-journal
*.sqlite3
*.sqlite3-journal

# Media (uploads de usuarios) - no subir archivos subidos
media/
/media/

# ---------- Entorno virtual ----------
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
ENV/

# ---------- Variables de entorno y secretos ----------
.env
.env.local
.env.*.local
*.pem
*.key
secret_key.txt

# ---------- Node / Frontend ----------
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Build de frontend ----------
frontend/dist/
frontend/build/
dist-ssr/
*.local

# ---------- Cobertura / tests ----------
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.coverage
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ---------- Logs ----------
logs/
*.log
*.out
*.pid
*.seed
*.pid.lock

# ---------- IDEs y editores ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------- Sistema operativo ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db

# ---------- Playwright / scraping ----------
# El scraper genera estos archivos temporales
scrape_output/
.scrapy/
*.har

# ---------- Misc ----------
*.bak
*.tmp
*.temp
.eslintcache
