# Copia este archivo como .env y ajusta los valores según tu entorno.

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Deja DB_ENGINE vacío (o coméntalo) para usar SQLite automáticamente.
# Ponlo en "postgres" para usar PostgreSQL con librechoice_schema.sql como referencia.
DB_ENGINE=
DB_NAME=librechoice
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
